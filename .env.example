# =========================================================================
# TaskManager - Variables de entorno para producción (docker-compose.yml)
# =========================================================================
# Copiá este archivo como `.env` y completá todos los valores antes de
# correr `docker compose up -d`. NO commitees el `.env` resultante.

# === PostgreSQL ===
POSTGRES_DB=taskmanager
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=change-me-strong-postgres-password

# === Redis (SignalR backplane + IDistributedCache) ===
REDIS_PASSWORD=change-me-strong-redis-password

# === Auth secrets ===
# Generá 32 bytes base64 con: openssl rand -base64 32
AUTH_MAGIC_LINK_SECRET=
AUTH_REFRESH_TOKEN_SECRET=

# Flag Secure de la cookie del refresh token.
# Dejá en `true` cuando sirvas la app por HTTPS.
# Poné `false` SOLO en despliegues HTTP (LAN, dev) donde el navegador
# descartaría la cookie por no cumplir el flag Secure.
AUTH_COOKIE_SECURE=true

# === Admin global (seed inicial si la DB está vacía) ===
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=
ADMIN_LAST_NAME=

# === URLs públicas (las que ven los usuarios, vía reverse proxy) ===
BACKEND_PUBLIC_URL=https://api.midominio.com
FRONTEND_PUBLIC_URL=https://app.midominio.com

# === URL del backend que se EMBEBE en el bundle del frontend en build-time ===
# Dejala VACÍA si el frontend y el backend se sirven detrás del mismo dominio/IP
# (el nginx del frontend proxea /api y /hubs al backend). Es el caso por defecto
# de este compose. El cliente HTTP usa rutas relativas → mismo origen → cookies OK.
#
# Solo seteala con un valor absoluto (ej. https://api.midominio.com) si el frontend
# y el backend viven en dominios distintos y tenés HTTPS + CORS configurados.
# Si cambiás este valor, rebuildear el frontend.
FRONTEND_BUILD_API_URL=

# === Puertos HOST publicados (apuntá tu reverse proxy externo acá) ===
BACKEND_HOST_PORT=5000
FRONTEND_HOST_PORT=8081

# === Email (Brevo) ===
# Si UseRealProvider=false, los emails se loguean en consola (LogOnly).
EMAIL_USE_REAL_PROVIDER=false
BREVO_API_KEY=

# === Observabilidad (opcional) ===
OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
